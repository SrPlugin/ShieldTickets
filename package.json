{
	"name": "shieldtickets",
	"author": "Sebastian Cheikh",
	"version": "1.0.0",
	"description": "A bot for managing tickets",
	"license": "MIT",
	"main": "dist/index.js",
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target bun --minify",
		"start": "bun run src/index.ts",
		"start:dev": "bun run src/index.ts --watch",
		"lint": "bunx --bun @biomejs/biome check --write"
	},
	"module": "index.ts",
	"type": "module",
	"private": false,
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@types/bun": "latest",
		"@types/pg": "^8.18.0",
		"drizzle-kit": "^0.31.9",
		"pino-pretty": "^13.1.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"drizzle-orm": "^0.45.1",
		"pg": "^8.19.0",
		"pino": "^10.3.1",
		"seyfert": "^4.2.2"
	}
}
